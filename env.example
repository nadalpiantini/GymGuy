# Supabase Configuration
# Para usar datos mock (desarrollo sin Supabase), usa estos valores:
NEXT_PUBLIC_SUPABASE_URL=https://placeholder.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=placeholder_key

# Para usar Supabase real, reemplaza con tus valores reales:
# NEXT_PUBLIC_SUPABASE_URL=tu_url_de_supabase
# NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_clave_anonima_de_supabase

# Stripe Configuration (opcional, para funciones premium)
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# App Configuration
# For local development:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# For production deployment:
# NEXT_PUBLIC_APP_URL=https://gymguy.sujeto10.com
