'use client'

import { useEffect } from 'react'

/**
 * Accessibility testing setup for development environment
 * This component loads axe-core in development to catch accessibility issues
 */
export function AccessibilityTesting() {
  useEffect(() => {
    // Only run in development and client-side
    if (process.env.NODE_ENV !== 'production' && typeof window !== 'undefined') {
      import('@axe-core/react').then(({ default: axe }) => {
        // Initialize axe-core/react
        axe(React, ReactDOM, 1000, {
          // Configuration options
          rules: {
            // You can disable specific rules here if needed
            // 'color-contrast': { enabled: false }
          },
          // Check these specific components
          includedImpacts: ['critical', 'serious', 'moderate', 'minor']
        })
      }).catch(err => {
        console.error('Failed to load axe-core:', err)
      })
    }
  }, [])

  return null
}

// Hook for manual accessibility testing
export function useAccessibilityAudit() {
  const runAudit = async () => {
    if (typeof window === 'undefined') return null

    try {
      // Dynamic import to avoid loading in production
      const axe = await import('axe-core')
      const results = await axe.default.run()

      if (results.violations.length > 0) {
        console.group('🔴 Accessibility Violations Found')
        results.violations.forEach(violation => {
          console.group(`[${violation.impact?.toUpperCase()}] ${violation.description}`)
          console.log('Help:', violation.help)
          console.log('Help URL:', violation.helpUrl)
          console.log('Affected nodes:', violation.nodes.length)
          violation.nodes.forEach(node => {
            console.log('  Element:', node.target)
            console.log('  HTML:', node.html)
          })
          console.groupEnd()
        })
        console.groupEnd()
      } else {
        console.log('✅ No accessibility violations found!')
      }

      return results
    } catch (error) {
      console.error('Error running accessibility audit:', error)
      return null
    }
  }

  return { runAudit }
}

// Accessibility checker component for specific sections
interface AccessibilityCheckerProps {
  children: React.ReactNode
  enabled?: boolean
}

export function AccessibilityChecker({ children, enabled = true }: AccessibilityCheckerProps) {
  useEffect(() => {
    if (!enabled || process.env.NODE_ENV === 'production') return

    const checkAccessibility = async () => {
      const container = document.getElementById('accessibility-check-container')
      if (!container) return

      try {
        const axe = await import('axe-core')
        const results = await axe.default.run(container)

        if (results.violations.length > 0) {
          console.warn('Accessibility issues in component:', results.violations)
        }
      } catch (error) {
        console.error('Accessibility check failed:', error)
      }
    }

    // Run check after a short delay to ensure DOM is ready
    const timeout = setTimeout(checkAccessibility, 500)
    return () => clearTimeout(timeout)
  }, [enabled, children])

  return (
    <div id="accessibility-check-container">
      {children}
    </div>
  )
}

// React import for axe-core
import React from 'react'
import ReactDOM from 'react-dom'

// Export a function to manually trigger accessibility tests
export async function testAccessibility(selector?: string) {
  if (typeof window === 'undefined') {
    console.warn('testAccessibility can only be run in the browser')
    return null
  }

  try {
    const axe = await import('axe-core')
    const element = selector ? document.querySelector(selector) : document.body

    if (!element) {
      console.error(`Element not found: ${selector}`)
      return null
    }

    const results = await axe.default.run(element as HTMLElement)

    // Format and display results
    const summary = {
      passes: results.passes.length,
      violations: results.violations.length,
      incomplete: results.incomplete.length,
      inapplicable: results.inapplicable.length
    }

    console.log('Accessibility Test Summary:', summary)

    if (results.violations.length > 0) {
      console.table(results.violations.map(v => ({
        impact: v.impact,
        description: v.description,
        nodes: v.nodes.length,
        help: v.help
      })))
    }

    return results
  } catch (error) {
    console.error('Accessibility test failed:', error)
    return null
  }
}

// Make the test function available globally in development
if (process.env.NODE_ENV !== 'production' && typeof window !== 'undefined') {
  (window as any).testAccessibility = testAccessibility
}